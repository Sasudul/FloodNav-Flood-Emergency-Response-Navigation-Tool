# ========================
#  FloodNav Root .gitignore
# ========================

# ---- Environment & Secrets ----
.env
.env.*
!.env.example

# ---- IDE / Editor ----
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ---- OS Generated ----
desktop.ini
ehthumbs.db
ehthumbs_vista.db

# ---- Node / Frontend ----
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.cache/

# ---- Java / Maven Backend ----
target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# ---- Maven Wrapper ----
.mvn/wrapper/maven-wrapper.jar

# ---- Build Outputs ----
build/
out/
bin/

# ---- Miscellaneous ----
*.bak
*.tmp
*.swp
*~
